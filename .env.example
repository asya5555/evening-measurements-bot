APP_ENV=local
APP_NAME=evening-measurements
DATABASE_URL=postgresql+asyncpg://diary:diary@postgres:5432/diary
TELEGRAM_BOT_TOKEN=123456:replace_me
TELEGRAM_ALLOWED_USER_IDS=123456789
TELEGRAM_ALLOWED_USERNAMES=
TELEGRAM_WEBHOOK_SECRET=replace_with_random_secret
PUBLIC_WEBHOOK_BASE_URL=https://example.com
AUTO_SET_WEBHOOK=false
OPENAI_API_KEY=sk-replace_me
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
DEFAULT_TIMEZONE=Europe/Tbilisi
MEDIA_RETENTION_DAYS=14
EXPORT_RETENTION_HOURS=24
LOG_LEVEL=INFO
